{
  "name": "llm-mock-server",
  "version": "1.0.2",
  "description": "A standalone mock LLM server for deterministic testing: OpenAI, Anthropic, and Responses API formats",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "llm-mock-server": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "lint": "oxlint --tsconfig tsconfig.json --import-plugin --vitest-plugin src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && npm run lint && npm test",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js"
  },
  "keywords": [
    "llm",
    "mock",
    "server",
    "openai",
    "anthropic",
    "testing",
    "sse"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "14.0.3",
    "fastify": "5.8.2",
    "json5": "2.2.3",
    "llm-schemas": "1.0.1",
    "picocolors": "1.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.0",
    "@vitest/coverage-v8": "4.1.0",
    "oxlint": "1.55.0",
    "tsx": "4.21.0",
    "typescript": "5.9.3",
    "vitest": "4.1.0"
  }
}
