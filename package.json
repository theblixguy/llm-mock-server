{
  "name": "llm-mock-server",
  "version": "1.0.8",
  "description": "A standalone mock LLM server for deterministic testing: OpenAI, Anthropic, and Responses API formats",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./package.json": "./package.json"
  },
  "imports": {
    "#*": {
      "llm-mock-server-dev": "./src/*",
      "default": "./dist/*"
    }
  },
  "files": [
    "dist"
  ],
  "bin": {
    "llm-mock-server": "./dist/cli/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "fmt": "oxfmt --write src/ test/",
    "fmt:check": "oxfmt --check src/ test/",
    "lint": "oxlint --tsconfig tsconfig.json --import-plugin --vitest-plugin src/ test/",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "tsc --noEmit && tsc --noEmit -p tsconfig.test.json && npm run fmt:check && npm run lint && npm test",
    "docs": "typedoc",
    "docs:check": "typedoc --emit none",
    "dev": "tsx -C llm-mock-server-dev src/cli/cli.ts",
    "start": "node dist/cli/cli.js"
  },
  "keywords": [
    "llm",
    "mock",
    "server",
    "openai",
    "anthropic",
    "testing",
    "sse"
  ],
  "license": "MIT",
  "dependencies": {
    "commander": "14.0.3",
    "fastify": "5.8.4",
    "json5": "2.2.3",
    "llm-schemas": "1.0.4",
    "picocolors": "1.1.1",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "25.5.2",
    "@vitest/coverage-v8": "4.1.4",
    "oxfmt": "0.44.0",
    "oxlint": "1.59.0",
    "tsx": "4.21.0",
    "typedoc": "0.28.18",
    "typedoc-theme-oxide": "0.2.5",
    "typescript": "6.0.2",
    "vitest": "4.1.4"
  }
}
